{
  "name": "codex-mermaid-enhancer",
  "version": "1.1.3",
  "description": "Codex-style Mermaid diagrams with pan-first navigation, shortcut zoom, fullscreen viewing, and touch gestures.",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "mermaid",
    "zoom",
    "pan",
    "codex-style"
  ],
  "devDependencies": {
    "@types/node": "^20.10.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.0",
    "obsidian": "latest",
    "typescript": "^5.3.0"
  }
}
